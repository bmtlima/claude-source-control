{
  "name": "multi-claude",
  "displayName": "Claude Source Control",
  "description": "Per-session source control panels for multiple Claude Code agents",
  "version": "0.1.13",
  "publisher": "bmtlima",
  "license": "MIT",
  "icon": "artifacts/cropped-logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multiClaude.stageFile",
        "title": "Stage Change",
        "icon": "$(add)"
      },
      {
        "command": "multiClaude.unstageFile",
        "title": "Unstage Change",
        "icon": "$(remove)"
      },
      {
        "command": "multiClaude.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "multiClaude.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "multiClaude.commit",
        "title": "Commit",
        "icon": "$(check)"
      },
      {
        "command": "multiClaude.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "multiClaude.discardAll",
        "title": "Discard All Changes",
        "icon": "$(discard)"
      },
      {
        "command": "multiClaude.commitSession",
        "title": "Commit Session"
      },
      {
        "command": "multiClaude.setupHook",
        "title": "Multi-Claude: Install Attribution Hook"
      },
      {
        "command": "multiClaude.refresh",
        "title": "Multi-Claude: Refresh Panels",
        "icon": "$(refresh)"
      },
      {
        "command": "multiClaude.dismissSession",
        "title": "Dismiss Session",
        "icon": "$(close)"
      },
      {
        "command": "multiClaude.revealTerminal",
        "title": "Reveal Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "multiClaude.showSessionPanel",
        "title": "Show Panel",
        "icon": "$(eye)"
      },
      {
        "command": "multiClaude.showAllPanels",
        "title": "Show All Panels",
        "icon": "$(checklist)"
      },
      {
        "command": "multiClaude.hideSessionPanel",
        "title": "Hide Panel",
        "icon": "$(eye-closed)"
      }
    ],
    "menus": {
      "scm/resourceState/context": [
        {
          "command": "multiClaude.discardFile",
          "group": "inline@1",
          "when": "scmProvider =~ /^multiClaude\\./"
        },
        {
          "command": "multiClaude.stageFile",
          "group": "inline@2",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup != 'staged'"
        },
        {
          "command": "multiClaude.unstageFile",
          "group": "inline@2",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'staged'"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "multiClaude.discardAll",
          "group": "inline@1",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'changes'"
        },
        {
          "command": "multiClaude.discardAll",
          "group": "inline@1",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'conflicts'"
        },
        {
          "command": "multiClaude.stageAll",
          "group": "inline@2",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'changes'"
        },
        {
          "command": "multiClaude.stageAll",
          "group": "inline@2",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'conflicts'"
        },
        {
          "command": "multiClaude.unstageAll",
          "group": "inline@2",
          "when": "scmProvider =~ /^multiClaude\\./ && scmResourceGroup == 'staged'"
        }
      ],
      "view/title": [
        {
          "command": "multiClaude.showAllPanels",
          "group": "navigation",
          "when": "view == multiClaude.sessions"
        },
        {
          "command": "multiClaude.refresh",
          "group": "navigation",
          "when": "view == multiClaude.sessions"
        }
      ],
      "view/item/context": [
        {
          "command": "multiClaude.showSessionPanel",
          "group": "inline",
          "when": "view == multiClaude.sessions && viewItem == sessionWithoutPanel"
        },
        {
          "command": "multiClaude.hideSessionPanel",
          "group": "inline",
          "when": "view == multiClaude.sessions && viewItem == sessionWithPanel"
        }
      ],
      "scm/title": [
        {
          "command": "multiClaude.commit",
          "group": "navigation@1",
          "when": "scmProvider =~ /^multiClaude\\./"
        },
        {
          "command": "multiClaude.discardAll",
          "group": "navigation@2",
          "when": "scmProvider =~ /^multiClaude\\./"
        },
        {
          "command": "multiClaude.refresh",
          "group": "navigation@3",
          "when": "scmProvider =~ /^multiClaude\\./"
        },
        {
          "command": "multiClaude.dismissSession",
          "group": "navigation@4",
          "when": "scmProvider =~ /^multiClaude\\./"
        }
      ]
    },
    "views": {
      "scm": [
        {
          "id": "multiClaude.sessions",
          "name": "Claude Sessions",
          "when": "multiClaude.hasActiveSessions"
        }
      ]
    },
    "viewsWelcome": [],
    "configuration": {
      "title": "Claude Source Control",
      "properties": {
        "multiClaude.autoCreatePanels": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create SCM panels when Claude sessions are detected. When disabled (default), sessions appear in the Claude Sessions tree view — click to show individual panels."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/test-electron": "^2.3.0"
  }
}
